# SVP 로컬 설정 템플릿 — 복사해서 .env로 저장하고 실제 값을 채운다.
#   cp .env.example .env      (Windows: copy .env.example .env)
# .env는 gitignore 대상이다. 사내 URL·PAT·실제 JQL은 .env에만 두고 절대 커밋하지 않는다.
# 우선순위: 셸 환경변수 > .env > 코드 기본값(mock)

# --- Jira 폴링 (F1) ---
# 기본값은 mock Jira (npm run mock:jira). 사내 테스트 시 실제 값으로 교체.
SVP_JIRA_BASE_URL=http://localhost:8792
SVP_JIRA_PAT=
SVP_JIRA_PROJECT=CIOPS
SVP_JIRA_LABEL=ci-failure
SVP_JIRA_POLL_MS=30000

# 팀의 CI 티켓이 project+label 조합이 아닌 경우 필터 전체를 지정 (설정 시 PROJECT/LABEL 무시).
# 폴러가 created 조건과 ORDER BY를 자동으로 덧붙이므로 여기엔 넣지 않는다.
# SVP_JIRA_JQL=project = XXX AND component = yyy AND assignee = zzz AND status != Resolved

# --- 기타 ---
# 기존 mock CI WebSocket (개발용 병존 경로)
# SVP_CI_WS_URL=ws://localhost:8790

# 사내 자체 CA 환경에서 Node의 TLS 신뢰용 인증서.
# 주의: 이 변수만은 .env로는 동작하지 않는다 (Node가 프로세스 시작 시점에 읽음).
# 셸에서 직접 설정할 것 — docs/SETUP.md 참고.
# NODE_EXTRA_CA_CERTS=C:\path\to\corp-root-ca.pem
