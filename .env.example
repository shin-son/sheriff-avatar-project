# SVP 로컬 설정 템플릿 — 복사해서 .env로 저장하고 실제 값을 채운다.
#   cp .env.example .env      (Windows: copy .env.example .env)
# .env는 gitignore 대상이다. 사내 URL·PAT·실제 JQL은 .env에만 두고 절대 커밋하지 않는다.
# 우선순위: 셸 환경변수 > .env > 코드 기본값(mock)

# ===== 서버 (npm run server) — Jira 접속은 전부 서버 몫 =====
# 기본값은 mock Jira (npm run mock:jira). 사내에서는 실제 값으로 교체.
SVP_JIRA_BASE_URL=http://localhost:8792
SVP_JIRA_PAT=

# 팀 CI 티켓 필터. ORDER BY는 서버가 자동으로 붙이므로 넣지 않는다.
# SVP_JIRA_JQL=project = XXX AND component = yyy AND assignee = zzz AND status != Resolved

# CI 봇 계정 — assignee가 이 값(또는 빈 값)이면 사람 배정 전 → 당번 큐
SVP_JIRA_BOT=cicd_ap
SVP_SERVER_PORT=8793
SVP_SERVER_POLL_MS=5000

# ===== 앱 (Windows 클라이언트) — 필요한 설정은 이것 하나 =====
# 서버가 원격(Linux 호스트)이면 http://<서버호스트>:8793
SVP_PUSH_URL=http://localhost:8793

# 사내 자체 CA 환경에서 Node의 TLS 신뢰용 인증서 (Jira에 접속하는 서버 호스트에서 필요).
# 주의: 이 변수만은 .env로는 동작하지 않는다 (Node가 프로세스 시작 시점에 읽음).
# 셸에서 직접, systemd 운영 시에는 유닛의 Environment=로 설정 — docs/SETUP.md 참고.
# NODE_EXTRA_CA_CERTS=/etc/ssl/certs/corp-root-ca.pem
