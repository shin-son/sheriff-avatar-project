# SVP 로컬 설정 템플릿 — 복사해서 .env로 저장하고 실제 값을 채운다.
#   cp .env.example .env      (Windows: copy .env.example .env)
# .env는 gitignore 대상이다. 사내 URL·PAT·실제 JQL은 .env에만 두고 절대 커밋하지 않는다.
# 우선순위: 셸 환경변수 > .env > 코드 기본값(mock)

# ===== 서버 (npm run server) — Jira 접속은 전부 서버 몫 =====
# 기본값은 mock Jira (npm run mock:jira). 사내에서는 실제 값으로 교체.
SVP_JIRA_BASE_URL=http://localhost:8792
SVP_JIRA_PAT=

# 팀 CI 티켓 필터. ORDER BY는 서버가 자동으로 붙이므로 넣지 않는다.
# SVP_JIRA_JQL=project = XXX AND component = yyy AND assignee = zzz AND status != Resolved

# CI 봇 계정 — assignee가 이 값(또는 빈 값)이면 사람 배정 전 → 당번 큐
SVP_JIRA_BOT=cicd_ap
SVP_SERVER_PORT=8793
SVP_SERVER_POLL_MS=5000

# ----- LLM 분류기 (F3) -----
# bedrock(Messages 엔드포인트) / bedrock-invoke(표준 InvokeModel — 사내) / anthropic(직접 API 키)
SVP_LLM_PROVIDER=bedrock-invoke
# AWS_REGION이 없으면 분류기 비활성 (티켓은 당번 큐 유지). 자격증명은 AWS 체인(SSO 프로필 등).
# AWS_REGION=
# AWS_PROFILE=
# 모델 기본값: bedrock-invoke는 global.anthropic.claude-opus-4-8 — 환경이 다를 때만 지정
# SVP_LLM_MODEL=
# SVP_ANTHROPIC_API_KEY=          # provider=anthropic일 때만

# ----- Jenkins (콘솔 로그 소스) -----
# 티켓 description의 빌드 링크에서 실패 로그(consoleText 꼬리)를 가져와 분류·ingest 로그를 보강.
# 기본값(미설정)은 인증 헤더 없이 시도 — mock Jenkins(npm run mock:jenkins)용.
# 사내는 Jenkins 프로필 → Configure → API Token 발급 후 아래 두 값 설정 (Basic auth).
# SVP_JENKINS_USER=
# SVP_JENKINS_TOKEN=
# SVP_JENKINS_LOG_TAIL=6000       # 콘솔 꼬리 폴백(TC 구간 못 찾을 때)의 유지 크기(chars). TC 구간은 통짜 보존
# SVP_JENKINS_TIMEOUT_MS=15000    # 샤드 콘솔이 ~9MB라 다운로드 여유 포함

# ----- Jira write 게이트 -----
# dry-run(기본 — 로그만) / label(SVP_TEST_LABEL 티켓만 write) / live(전면)
SVP_JIRA_WRITE_MODE=dry-run
# SVP_TEST_LABEL=svp-test
# SVP_LLM_CONFIDENCE_MIN=80

# 서버가 분류 근거로 읽는 vault 폴더 (기본: repo의 wiki-vault — 사내는 별도 클론 경로 지정)
# SVP_WIKI_DIR=

# 설정 시 신규 티켓의 수집 로그(description + Jenkins 구간)를 <dir>/<티켓키>.log로 저장.
# ingest 전 수집 데이터 검증용 — 기본 꺼짐.
# SVP_DEBUG_DUMP_DIR=/tmp/svp-dump

# ===== 앱 (Windows 클라이언트) — 필요한 설정은 이것 하나 =====
# 서버가 원격(Linux 호스트)이면 http://<서버호스트>:8793
SVP_PUSH_URL=http://localhost:8793

# 사내 자체 CA 환경에서 Node의 TLS 신뢰용 인증서 (Jira에 접속하는 서버 호스트에서 필요).
# 주의: 이 변수만은 .env로는 동작하지 않는다 (Node가 프로세스 시작 시점에 읽음).
# 셸에서 직접, systemd 운영 시에는 유닛의 Environment=로 설정 — docs/SETUP.md 참고.
# NODE_EXTRA_CA_CERTS=/etc/ssl/certs/corp-root-ca.pem
